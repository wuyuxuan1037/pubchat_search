# -----------------------------------------------------------------------------
# Environment variables for PubMed Meta-Analysis Workflow
#
# Instructions:
# 1. Copy this file to a new file named .env in the same directory.
# 2. Fill in the values for the variables below.
# 3. DO NOT commit the .env file to version control.
# -----------------------------------------------------------------------------

# (Optional but Recommended) Your NCBI API Key for PubMed.
# This provides a higher request rate limit.
# You can obtain one from your NCBI account settings after logging in.
# See: https://www.ncbi.nlm.nih.gov/books/NBK25497/#chapter2.Getting_an_API_Key
# PUBMED_API_KEY="fbf5ffab87c121c8eeaaa1c4278727299608;9fc9e852f1648e302c5bcb2d5f8558d46408;1d9a1cfbe06b7202316651255afa71209208;a1eb6228a2b76e101564b689bffc94f95508;9b0de3da446aabd777cb6825a77867197008;da361bdd993c85a319b6b8bf482f979dc508;29563e85a140f011f08508d6d71c452e3d08;84184efa7f202211dac1669c0a38c438e208;8beaec8bb9eedd4a6e32159d7357ec815b09;eb3a48a4562d700bfabd883dbc1f52c09908;6cfbe3761811d8219178a6cbae6857147d08"

# Google Gemini API Key
# GOOGLE_API_KEY="AIzaSyD_PSH-ecoaUzBj0wOSL7T17dhFHcUdyuA;AIzaSyA7bOwWkaYB2FtMsuxNwi8CNZSAsPM1MKI;AIzaSyBaTpRkgwdkj4voig50UEBMt6VseZe32cc"

